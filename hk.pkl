amends "package://github.com/jdx/hk/releases/download/v1.32.0/hk@1.32.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.32.0/hk@1.32.0#/Builtins.pkl"

// Elixir linters for Levee (run from server/ directory)
local elixir_linters = new Mapping<String, Step> {
    // Format Elixir code with mix format
    ["mix_fmt"] {
        glob = "server/**/*.ex"
        batch = true
        fix = "cd server && mix format"
        check = "cd server && mix format --check-formatted"
    }

    // Compile with warnings as errors
    ["mix_compile"] {
        glob = "server/**/*.ex"
        batch = true
        check = "cd server && mix compile --warnings-as-errors"
    }
}

// Full test suite (slower, for pre-push or manual checks)
local test_linters = new Mapping<String, Step> {
    ["mix_test"] {
        glob = "server/**/*.ex"
        batch = true
        check = "cd server && mix test"
    }
}

// PKL config validation
local config_linters = new Mapping<String, Step> {
    ["pkl"] {
        glob = "*.pkl"
        check = "pkl eval {{files}} >/dev/null"
    }
}

hooks {
    // Pre-commit: format and compile checks (fast, blocks commit on failure)
    ["pre-commit"] {
        fix = true    // auto-fix formatting issues
        stage = true  // auto-stage fixed files
        stash = "git" // stash unstaged changes while running fixes
        steps {
            ...elixir_linters
            ...config_linters
        }
    }

    // Pre-push: run full test suite (slower, blocks push on failure)
    ["pre-push"] {
        steps {
            ...elixir_linters
            ...test_linters
        }
    }

    // Manual fix command: hk fix
    ["fix"] {
        fix = true
        steps {
            ...elixir_linters
            ...config_linters
        }
    }

    // Manual check command: hk check (add --slow for tests)
    ["check"] {
        steps {
            ...elixir_linters
            ...config_linters
            // Tests only run with --slow flag
            ["mix_test"] {
                glob = "server/**/*.ex"
                batch = true
                check = "cd server && mix test"
                profiles = List("slow")
            }
        }
    }
}
