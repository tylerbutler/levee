{
	"name": "@tylerbu/levee-client-workspace",
	"version": "0.0.0",
	"private": true,
	"description": "TypeScript client packages for Levee collaborative document service",
	"license": "MIT",
	"author": "Tyler Butler <tyler@tylerbutler.com>",
	"type": "module",
	"scripts": {
		"build": "workspaces-to-typescript-project-references && tsc --build",
		"check": "biome check .",
		"check:format": "biome format .",
		"check:references": "workspaces-to-typescript-project-references --check",
		"fix:references": "workspaces-to-typescript-project-references",
		"clean": "rimraf --glob \"packages/*/esm\" \"packages/*/dist\" \"packages/*/*.tsbuildinfo\"",
		"format": "biome check . --linter-enabled=false --write",
		"lint": "biome lint .",
		"lint:fix": "biome lint . --write",
		"test": "vitest run",
		"test:integration": "start-server-and-test 'docker compose -f packages/levee-driver/docker-compose.yml up' http://localhost:4000/health 'vitest run integration'",
		"test:integration:up": "docker compose -f packages/levee-driver/docker-compose.yml up -d --wait",
		"test:integration:down": "docker compose -f packages/levee-driver/docker-compose.yml down -v",
		"test:integration:run": "vitest run integration",
		"ci:publish": "pnpm publish -r --access public --provenance --report-summary --no-git-checks"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.8",
		"@monorepo-utils/workspaces-to-typescript-project-references": "^2.11.0",
		"@tsconfig/node18": "^18.2.6",
		"rimraf": "^6.1.2",
		"start-server-and-test": "^2.1.3",
		"typescript": "~5.9.3",
		"vitest": "^4.0.18"
	},
	"packageManager": "pnpm@10.24.0"
}
