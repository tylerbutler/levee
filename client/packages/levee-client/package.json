{
	"name": "@tylerbu/levee-client",
	"version": "0.1.2",
	"description": "Client for the Levee Fluid Framework service.",
	"bugs": "https://github.com/tylerbutler/levee/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tylerbutler/levee.git",
		"directory": "client/packages/levee-client"
	},
	"license": "MIT",
	"author": "Tyler Butler <tyler@tylerbutler.com>",
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./esm/index.d.ts",
				"default": "./esm/index.js"
			}
		}
	},
	"main": "esm/index.js",
	"types": "esm/index.d.ts",
	"files": [
		"esm"
	],
	"scripts": {
		"build:compile": "tsc",
		"check": "pnpm check:format",
		"check:format": "biome format .",
		"clean": "rimraf --glob esm \"**/*.tsbuildinfo\" \"**/*.build.log\" _temp",
		"format": "biome check . --linter-enabled=false --write",
		"lint": "biome lint",
		"lint:fix": "biome lint --write",
		"test:coverage": "vitest run --coverage test",
		"test:integration": "start-server-and-test 'docker compose up' http://localhost:4000/health 'vitest run test/integration'",
		"test:integration:down": "docker compose down -v",
		"test:integration:local": "start-server-and-test 'docker compose -f docker-compose.yml -f docker-compose.local.yml up --build' http://localhost:4000/health 'vitest run test/integration'",
		"test:integration:logs": "docker compose logs -f levee",
		"test:integration:up": "docker compose up -d --wait",
		"test:integration:up:local": "docker compose -f docker-compose.yml -f docker-compose.local.yml up -d --wait --build",
		"test:vitest": "vitest run test"
	},
	"dependencies": {
		"@fluidframework/container-definitions": "<2.100.0",
		"@fluidframework/container-loader": "<2.100.0",
		"@fluidframework/core-interfaces": "<2.100.0",
		"@fluidframework/driver-definitions": "<2.100.0",
		"@fluidframework/fluid-static": "<2.100.0",
		"@fluidframework/telemetry-utils": "<2.100.0",
		"@tylerbu/levee-driver": "workspace:^"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.8",
		"@fluidframework/map": "<2.100.0",
		"@tsconfig/node18": "^18.2.6",
		"@types/node": "^20.19.25",
		"@vitest/coverage-v8": "^4.0.18",
		"rimraf": "^6.1.2",
		"start-server-and-test": "^2.1.3",
		"typescript": "~5.9.3",
		"vitest": "^4.0.18"
	}
}
